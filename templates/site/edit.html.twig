{% extends 'layout.html.twig' %}

{% block title %}Éditer {{ site.name }} — Watcha{% endblock %}
{% block heading %}Éditer {{ site.name }}{% endblock %}

{% block content %}
    <div class="page-header"><div>
        <h1>Technologie & version</h1>
        <p>Indiquez la technologie et la version de votre application. Ces deux informations sont
           nécessaires pour rechercher les CVE et la dernière version stable lors du scan.</p>
    </div></div>

    <div class="card" style="max-width:560px">
        <div class="card__body">
            {{ form_start(form, {attr: {class: 'form'}}) }}
                <div class="form-row">
                    {{ form_label(form.manualTechnology) }}
                    {{ form_widget(form.manualTechnology) }}
                    {{ form_errors(form.manualTechnology) }}
                </div>
                <div class="form-row">
                    {{ form_label(form.manualVersion) }}
                    {{ form_widget(form.manualVersion) }}
                    {% if form.manualVersion.vars.help %}<span class="help">{{ form.manualVersion.vars.help }}</span>{% endif %}
                    {{ form_errors(form.manualVersion) }}
                </div>
                <div class="row">
                    <button class="btn" type="submit">Enregistrer</button>
                    <a href="{{ path('app_site_show', {id: site.id}) }}" class="btn btn--outline">Annuler</a>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
