{% extends 'emails/base.html.twig' %}

{% block subject %}Votre compte est activé{% endblock %}

{% block content %}
    <p style="margin:0 0 16px;">Bonjour{% if displayName %} {{ displayName }}{% endif %},</p>
    <p style="margin:0 0 16px;">
        Votre compte Watcha a été validé : vous pouvez désormais vous connecter et commencer à
        surveiller vos sites.
    </p>
    <p style="margin:0 0 8px;">
        <a href="{{ loginUrl }}" style="display:inline-block;padding:10px 18px;background:#111827;color:#ffffff;text-decoration:none;border-radius:8px;font-weight:600;">
            Se connecter
        </a>
    </p>
    <p style="margin:16px 0 0;font-size:13px;color:#6b7280;">
        Ou copiez ce lien : {{ loginUrl }}
    </p>
{% endblock %}
