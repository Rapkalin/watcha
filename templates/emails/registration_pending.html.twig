{% extends 'emails/base.html.twig' %}

{% block subject %}Nouveau compte à valider{% endblock %}

{% block content %}
    <p style="margin:0 0 16px;">Bonjour,</p>
    <p style="margin:0 0 16px;">
        Une nouvelle inscription est en attente de validation sur Watcha :
        <strong>{{ pendingEmail }}</strong>.
    </p>
    <p style="margin:0 0 16px;">
        Adresse e-mail :
        {% if pendingVerified %}
            <strong style="color:#15803d;">confirmée</strong>.
        {% else %}
            <strong style="color:#a16207;">pas encore confirmée</strong> — vous pouvez tout de même
            approuver le compte si vous le souhaitez.
        {% endif %}
    </p>
    <p style="margin:0 0 24px;">
        Tant que le compte n'est pas approuvé, l'utilisateur ne peut pas se connecter.
    </p>
    <p style="margin:0 0 8px;">
        <a href="{{ adminUrl }}" style="display:inline-block;padding:10px 18px;background:#111827;color:#ffffff;text-decoration:none;border-radius:8px;font-weight:600;">
            Gérer les comptes
        </a>
    </p>
    <p style="margin:16px 0 0;font-size:13px;color:#6b7280;">
        Ou copiez ce lien : {{ adminUrl }}
    </p>
{% endblock %}
