{% extends 'emails/base.html.twig' %}

{% block subject %}Réinitialisation de votre mot de passe{% endblock %}

{% block content %}
    <p style="margin:0 0 16px;">Bonjour{% if displayName %} {{ displayName }}{% endif %},</p>
    <p style="margin:0 0 16px;">
        Vous avez demandé à réinitialiser votre mot de passe Watcha. Cliquez sur le bouton ci-dessous
        pour en choisir un nouveau.
    </p>
    <p style="margin:0 0 8px;">
        <a href="{{ url('app_reset_password', {token: resetToken.token}) }}" style="display:inline-block;padding:10px 18px;background:#111827;color:#ffffff;text-decoration:none;border-radius:8px;font-weight:600;">
            Réinitialiser mon mot de passe
        </a>
    </p>
    <p style="margin:16px 0 0;font-size:13px;color:#6b7280;">
        Ce lien expire le {{ resetToken.expiresAt|date('d/m/Y à H:i') }}. Si vous n'êtes pas à
        l'origine de cette demande, ignorez cet e-mail : votre mot de passe reste inchangé.
    </p>
{% endblock %}
