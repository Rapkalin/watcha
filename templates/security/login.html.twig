{% extends 'base.html.twig' %}

{% block title %}Connexion — Watcha{% endblock %}

{% block layout %}
    <div class="auth">
        <div class="auth__card">
            <div class="auth__brand"><span class="sidebar__logo">🛡️</span> Watcha</div>

            {% for message in app.flashes('success') %}
                <div class="alert alert--success"><span>{{ message }}</span></div>
            {% endfor %}

            <div class="card">
                <div class="card__header">
                    <div class="card__title">Connexion</div>
                    <div class="card__desc">Accédez à votre tableau de bord de veille des vulnérabilités.</div>
                </div>
                <div class="card__body">
                    {% if error %}
                        <div class="alert alert--error"><span>{{ error.messageKey|trans(error.messageData, 'security') }}</span></div>
                    {% endif %}

                    <form method="post" class="form">
                        <div class="form-row">
                            <label for="username">Adresse e-mail</label>
                            <input type="email" id="username" name="_username" value="{{ last_username }}" autocomplete="email" required autofocus>
                        </div>
                        <div class="form-row">
                            <label for="password">Mot de passe</label>
                            <input type="password" id="password" name="_password" autocomplete="current-password" required>
                        </div>
                        <label class="row text-sm">
                            <input type="checkbox" name="_remember_me" style="width:auto;height:auto"> Se souvenir de moi
                        </label>
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                        <button class="btn btn--block" type="submit">Se connecter</button>
                    </form>
                </div>
                <div class="card__footer text-sm muted">
                    Pas encore de compte ? <a href="{{ path('app_register') }}" style="text-decoration:underline">Créer un compte</a>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
